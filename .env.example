# Cloudflare Workers uses secrets, NOT .env files for production
# Use this file only for reference

# Set your Groq API key as a Worker secret:
# npx wrangler secret put GROQ_API_KEY
# (then paste your key: gsk_...)

# For local development only, create a .dev.vars file:
# GROQ_API_KEY=gsk_your_key_here
